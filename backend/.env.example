DATABASE_URL="postgresql://rtcars:rtcars@localhost:5433/rtcars"
REDIS_URL="redis://localhost:6379"

JWT_SECRET="change-me-minimum-32-characters-long"
JWT_REFRESH_SECRET="change-me-different-from-jwt-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Auth tuning (optional — defaults used if not set)
BCRYPT_ROUNDS=10
REFRESH_TOKEN_TTL_DAYS=7

PORT=4000
NODE_ENV=development

# Scraping
SCRAPE_COPART_ENABLED=true
SCRAPE_IAA_ENABLED=true
SCRAPE_INTERVAL_HOURS=4

# CORS — set to frontend URL in production
CORS_ORIGIN="http://localhost:3000"
